# ── Telegram ──────────────────────────────────────────────
# Режим: public або public_private
TELEGRAM_MODE=public

# API ключі (потрібні тільки для приватних каналів)
# Отримати на https://my.telegram.org → App configuration
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Канали постачальників через кому.
# Формат: @канал або https://t.me/канал, опційно з патерном: :A, :B, :C, :AUTO
#
# Паттерни:
#   A    — спочатку медіа, потім окремий текст
#   B    — спочатку текст, потім окремо медіа
#   C    — текст вбудований у caption медіа (звичайний пост)
#   AUTO — визначати автоматично (якщо не впевнений)
#
TELEGRAM_CHANNELS=@channel1:A,@channel2:C,@channel3:AUTO

# Максимальний проміжок між медіа та текстом (в секундах)
# щоб вважати їх одним товаром
# 600  = 10 хв (якщо автор публікує швидко)
# 1200 = 20 хв (стандарт)
# 1800 = 30 хв (якщо автор публікує повільно)
TEXT_WINDOW_SECONDS=1200

# ── MyDrop ────────────────────────────────────────────────
# MyDrop → Інтеграції → API ключ
MYDROP_TOKEN=

# ── KeyCRM ────────────────────────────────────────────────
# KeyCRM → Налаштування → API
KEYCRM_KEY=
